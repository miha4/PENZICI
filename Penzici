Public Sub ZazeniPredlogIzrabe()
    On Error GoTo Konec
    
    frmLoading.Show vbModeless
    DoEvents
    SetLoaderProgress 0, "Začenjam..."
    
    Call PripraviPredlogIzrabe
    
Konec:
    Unload frmLoading
End Sub

Public Sub PripraviPredlogIzrabe()
    On Error GoTo FailHandler

    LogDebug "=== ZAGON PripraviPredlogIzrabe ==="
    SetLoaderProgress 5, "Začenjam..."

    Dim wS As Worksheet
    Set wS = ActiveSheet
    
    'Preberemo datum upokojitve v E3; ReadDateFromCell preveri ali je res datum
    Dim retirementDate As Date
    retirementDate = ReadDateFromCell(wS.Range("E3"), "E3 (datum upokojitve)")
    LogDebug "Datum upokojitve: " & Format$(retirementDate, "dd.mm.yyyy")

    'Preberemo blokirane izmene, ki jih ne prepišemo z dopustom
    Dim blocked As Object
    Set blocked = ParseBlockedShifts(CStr(wS.Range("D12").Value))

    'ustvarimo prazen seznam
    Dim planItems As Collection
    'pokličemo funkcijo, ki sestavi seznam
    Set planItems = ReadLeaveItemsFixed(wS)
    
    If planItems.Count = 0 Then
        SetLoaderProgress 100, "Ni dopustov za planiranje."
        MsgBox "Ni dopustov za planiranje (E5:E9).", vbExclamation
        Exit Sub
    End If
    LogDebug "Število tipov dopusta za planiranje: " & planItems.Count
    
    'Pozenemo sortiranje po prioriteti: D, L, G, GL, GP
    SortLeaveItemsByPriority planItems, retirementDate

    Dim src As Range
    Dim dst As Range
    
    Set src = wS.Range("RazporedDelavca")
    Set dst = wS.Range("VpisiDopuste")
    SetLoaderProgress 20, "Pripravljam območja..."

    LogDebug "Vir urnika: " & src.Address(False, False) & " (ime: " & GetRangeName(src) & ")"
    LogDebug "Cilj vpisa: " & dst.Address(False, False) & " (ime: VpisiDopuste)"

    'Če območji nista enaki
    If src.Rows.Count <> dst.Rows.Count Or src.Columns.Count <> dst.Columns.Count Then
        Err.Raise vbObjectError + 501, , "Območji RazporedDelavca in VpisiDopuste morata biti enake velikosti."
    End If
    
    'pobriše VpisiDopuste matriko
    dst.Value = src.Value
    dst.Font.Color = vbBlack
    wS.Range("E16:E20").ClearContents
    LogDebug "VpisiDopuste in Razporejen dopust je počiščen."
    
    ClearPostRetirementPlan src, dst, retirementDate
    SetLoaderProgress 30, "Čistim in označujem datume..."
    HighlightImportantDates src, dst, retirementDate

    Dim i As Long
    'Zanka po vseh dopustih, ki jih je potrebno razporediti
    Dim totalAssigned As Long
    For i = 1 To planItems.Count
        SetLoaderProgress 30 + CLng((i - 1) * 60 / planItems.Count), "Planiram tip " & CStr(planItems(i)(0)) & "..."
        Dim item As Variant
        item = planItems(i) ' item(0)=Code, item(1)=Qty, item(2)=ValidUntil
        LogDebug "Začenjam tip: " & CStr(item(0)) & ", qty=" & CLng(item(1)) & ", veljavnost=" & Format$(CDate(item(2)), "dd.mm.yyyy")
        'GLAVNI DEL MAKROJA, PLANIRANJE DOPUSTA; VHODNI PODATKI: RazporedDelavca, matrika VpisiDopuste, blokirane izmene, Upokojitveni datum,
        ' item(0) - oznaka dopusta, item(1) - stevilo dni, item(2) - veljaven do
        'FunkcijaPlanOneLeaveItem vrne splanirane dopuste, kar zapišemo v assignedQty
        Dim assignedQty As Long
        assignedQty = PlanOneLeaveItem(src, dst, blocked, retirementDate, CStr(item(0)), CLng(item(1)), CDate(item(2)))
        'Zapisemo planirane dopuste
        WriteAssignedQty wS, CStr(item(0)), assignedQty
        totalAssigned = totalAssigned + assignedQty
    Next i
    
    WarnIfLeavesCannotBeCombined src, dst, retirementDate, totalAssigned

    SetLoaderProgress 100, "Zaključujem..."
    LogDebug "=== KONEC PripraviPredlogIzrabe ==="
    MsgBox "Predlog izrabe je pripravljen v območju VpisiDopuste.", vbInformation
    Exit Sub

FailHandler:
    SetLoaderProgress 100, "Napaka."
    LogDebug "NAPAKA: " & Err.Description
    MsgBox "Napaka: " & Err.Description, vbCritical
End Sub

Private Function GetRangeName(ByVal rng As Range) As String
    Dim n As Name
    For Each n In rng.Worksheet.Parent.Names
        On Error Resume Next
        If n.RefersToRange.Address = rng.Address Then
            GetRangeName = n.Name
            Exit Function
        End If
        On Error GoTo 0
    Next n
    GetRangeName = "(brez imena)"
End Function


'Funkcija ustvari seznam in pokliče funkcijo, ki preveri dopuste in jih doda v seznam
Private Function ReadLeaveItemsFixed(ByVal wS As Worksheet) As Collection
    'prazen seznam
    Dim result As New Collection
    
    '5x pokliče AddLeaveIfAny:
    AddLeaveIfAny result, wS.Range("D5").Value, wS.Range("E5").Value, wS.Range("F5").Value
    AddLeaveIfAny result, wS.Range("D6").Value, wS.Range("E6").Value, wS.Range("F6").Value
    AddLeaveIfAny result, wS.Range("D7").Value, wS.Range("E7").Value, wS.Range("F7").Value
    AddLeaveIfAny result, wS.Range("D8").Value, wS.Range("E8").Value, wS.Range("F8").Value
    AddLeaveIfAny result, wS.Range("D9").Value, wS.Range("E9").Value, wS.Range("F9").Value

    Set ReadLeaveItemsFixed = result
End Function
'Funkcija pridobi: prazen seznam result, leaveCode = "L, D,...", qtyVal = 5,... validVal = 31.12.2026
Private Sub AddLeaveIfAny(ByRef col As Collection, ByVal leaveCode As String, ByVal qtyVal As Variant, ByVal validVal As Variant)
    If Not IsNumeric(qtyVal) Then Exit Sub
    If CLng(qtyVal) <= 0 Then Exit Sub
    If Not IsDate(validVal) Then
        Err.Raise vbObjectError + 601, , "Veljavnost ni datum za tip " & leaveCode & "."
    End If
    'dodajanje v seznam
    col.Add Array(leaveCode, CLng(qtyVal), DateValue(CDate(validVal)))
End Sub

Private Function ParseBlockedShifts(ByVal raw As String) As Object
    Dim dict As Object
    Set dict = CreateObject("Scripting.Dictionary")
    dict.CompareMode = 1 ' TextCompare

    Dim parts() As String
    'gre čez vse dele, odstrani presledke in jih zapiše v slovar
    Dim i As Long
    ' ločilo je vejica
    parts = Split(raw, ",")
    For i = LBound(parts) To UBound(parts)
        Dim token As String
        token = Trim$(parts(i))
        If Len(token) > 0 Then
            dict(UCase$(token)) = True
            LogDebug "Blokirana izmena: " & UCase$(token)
        End If
    Next i

    Set ParseBlockedShifts = dict
End Function
'====================================================================================================================
' ========================== GLAVNI MOTOR MAKROJA: PISANJE DOPUSTOV =================================================
'====================================================================================================================
Private Function PlanOneLeaveItem(ByVal src As Range, ByVal dst As Range, ByVal blocked As Object, ByVal retirementDate As Date, ByVal leaveCode As String, ByVal leaveQty As Long, ByVal validUntil As Date) As Long
    PlanOneLeaveItem = PlanOneLeaveItemWithWindow(src, dst, blocked, retirementDate, leaveCode, leaveQty, validUntil, DateSerial(1900, 1, 1), LastWorkingDay(retirementDate), True)
End Function

Private Function PlanOneLeaveItemWithWindow(ByVal src As Range, ByVal dst As Range, ByVal blocked As Object, ByVal retirementDate As Date, ByVal leaveCode As String, ByVal leaveQty As Long, ByVal validUntil As Date, ByVal windowStart As Date, ByVal windowEnd As Date, ByVal reverseOrder As Boolean) As Long
    'Koliko dopusta še ni razporejeno
    Dim remaining As Long
    remaining = leaveQty
    Dim lastWorkDate As Date
    lastWorkDate = LastWorkingDay(retirementDate)
    
    Dim effectiveEndDate As Date
    effectiveEndDate = BaseEffectiveEndDate(leaveCode, validUntil, retirementDate)
    
    Dim scheduleMinDate As Date, scheduleMaxDate As Date
    GetScheduleDateBounds src, scheduleMinDate, scheduleMaxDate
    effectiveEndDate = AlignEndDateToVisibleSchedule(effectiveEndDate, scheduleMinDate, scheduleMaxDate, retirementDate)
    
    Dim hasValidityWindow As Boolean                    ' Obstaja časovno okno, kjer se planiranje dopustov izzide
    Dim gCutoffDate As Date                             'omejitev za planiranje G-jev
    gCutoffDate = DateAdd("d", -45, lastWorkDate)
    
    effectiveEndDate = ApplyLeaveTypeHardStops(leaveCode, effectiveEndDate, retirementDate, gCutoffDate)

    Dim r As Long, c As Long
    Dim lastKnownYear As Long                           'v resnici števec stolpcev

    Dim candR() As Long, candC() As Long, candDt() As Double
    Dim candCount As Long
    
    For r = 1 To src.Rows.Count

        Dim rowLabel As String                          ' meseci ?
        rowLabel = CStr(src.Worksheet.Cells(src.Row + r - 1, src.Column - 1).Value)

        Dim yy As Long, mm As Long
        'pregleda leto in mesec in ga spravi v pravi format
        If Not ResolveYearMonthForRow(src.Worksheet, src.Row + r - 1, src.Column, yy, mm, lastKnownYear) Then
            LogDebug "[" & leaveCode & "] Preskok vrstice (neveljaven mesec/leto): '" & rowLabel & "'"
            GoTo NextRow
        End If

        LogDebug "[" & leaveCode & "] Pregled vrstice: " & yy & " " & rowLabel

        For c = 1 To src.Columns.Count
            
            'Preverjanje ali ta dan sploh obstaja
            Dim d As Long
            d = c
            If d > Day(DateSerial(yy, mm + 1, 0)) Then
                LogDebug "[" & leaveCode & "] Dan " & d & " ne obstaja v mesecu " & mm & "/" & yy
                GoTo NextCol
            End If
            
            'Sestava pravega datuma
            Dim dt As Date
            dt = DateSerial(yy, mm, d)
            
            
            'Branje izmen koledarja
            Dim shiftCode As String
            shiftCode = Trim$(CStr(src.Cells(r, c).Value))

            LogDebug "[" & leaveCode & "] Dan " & Format$(dt, "dd.mm.yyyy") & _
                     " | shift='" & shiftCode & "' | remaining=" & remaining
            
            'pogleda če je dan ustrezen:
            'a) če je po zadnjem mogočem datumu za ta tip dopusta
            If dt > effectiveEndDate Then
                LogDebug "  -> preskok (po zadnjem možnem datumu: " & Format$(effectiveEndDate, "dd.mm.yyyy") & ")"
                GoTo NextCol
            End If
            'Če najdemo vsaj 1 datum, ki je datumsko še mogoč
            hasValidityWindow = True
            
            'Če je prazna celica, jo preskoči
            If Len(shiftCode) = 0 Then
                LogDebug "  -> preskok (prazna celica)"
                GoTo NextCol
            End If
            ' Če je blokirana celica
            If blocked.Exists(UCase$(shiftCode)) Then
                LogDebug "  -> preskok (blokirana izmena)"
                GoTo NextCol
            End If
            'Preskočimo, če je že vpisano nekaj
            If Trim$(CStr(dst.Cells(r, c).Value)) <> Trim$(CStr(src.Cells(r, c).Value)) Then
                LogDebug "  -> preskok (že prepisano v VpisiDopuste)"
                GoTo NextCol
            End If

            candCount = candCount + 1
            ReDim Preserve candR(1 To candCount)
            ReDim Preserve candC(1 To candCount)
            ReDim Preserve candDt(1 To candCount)
            candR(candCount) = r
            candC(candCount) = c
            candDt(candCount) = CDbl(dt)

NextCol:
        Next c
NextRow:
    Next r
    
    Dim idx As Long, j As Long
    For idx = 1 To candCount - 1
        For j = idx + 1 To candCount
            If candDt(j) > candDt(idx) Then
                SwapCandidate candR, candC, candDt, idx, j
            End If
        Next j
    Next idx
    
    For idx = 1 To candCount
        If remaining <= 0 Then Exit For
        
        With dst.Cells(candR(idx), candC(idx))
            .Font.Color = vbBlack   ' reset
            .Value = leaveCode
            .Font.Color = vbRed     ' VSAK dopust = rdeče
        End With
        
        remaining = remaining - 1
    Next idx

    If remaining > 0 Then
        If Not hasValidityWindow Then
            LogDebug "[" & leaveCode & "] ZAKLJUČEK: ni termina do " & Format$(effectiveEndDate, "dd.mm.yyyy")
        ShowUserMessage "Za tip '" & leaveCode & "' planiranje ni možno: v tabeli ni termina do " & Format$(effectiveEndDate, "dd.mm.yyyy") & ".", vbInformation
        Else
            LogDebug "[" & leaveCode & "] ZAKLJUČEK: premalo dni, manjka " & remaining
            ShowUserMessage "Za tip '" & leaveCode & "' ni dovolj prostih dni. Manjka: " & remaining, vbInformation
        End If
    Else
        LogDebug "[" & leaveCode & "] ZAKLJUČEK: uspešno razporejeno."
    End If
    
    'Vpišimo planirani dopust v E16-E20
    PlanOneLeaveItemWithWindow = leaveQty - remaining
    
End Function

Private Sub GetScheduleDateBounds(ByVal src As Range, ByRef minDate As Date, ByRef maxDate As Date)
    Dim r As Long, c As Long
    Dim yy As Long, mm As Long
    Dim lastKnownYear As Long
    Dim found As Boolean
    
    For r = 1 To src.Rows.Count
        If Not ResolveYearMonthForRow(src.Worksheet, src.Row + r - 1, src.Column, yy, mm, lastKnownYear) Then
            GoTo NextRow
        End If
        
        For c = 1 To src.Columns.Count
            If c > Day(DateSerial(yy, mm + 1, 0)) Then GoTo NextCol
            
            Dim dt As Date
            dt = DateSerial(yy, mm, c)
            If Not found Then
                minDate = dt
                maxDate = dt
                found = True
            Else
                If dt < minDate Then minDate = dt
                If dt > maxDate Then maxDate = dt
            End If
NextCol:
        Next c
NextRow:
    Next r
End Sub

Private Function AlignEndDateToVisibleSchedule(ByVal endDate As Date, ByVal scheduleMinDate As Date, ByVal scheduleMaxDate As Date, ByVal retirementDate As Date) As Date
    Dim adjusted As Date
    adjusted = endDate
    
    If adjusted < scheduleMinDate Then
        adjusted = DateSerial(Year(scheduleMinDate), Month(adjusted), Day(adjusted))
        If adjusted < scheduleMinDate Then
            adjusted = DateAdd("yyyy", 1, adjusted)
        End If
        
        If adjusted > scheduleMaxDate Or adjusted > retirementDate Then
            adjusted = endDate
        End If
    End If
    
    AlignEndDateToVisibleSchedule = adjusted
End Function

Private Sub ClearPostRetirementPlan(ByVal src As Range, ByVal dst As Range, ByVal retirementDate As Date)
    Dim r As Long, c As Long
    Dim yy As Long, mm As Long
    Dim lastKnownYear As Long
    Dim dstArr As Variant
    
    dstArr = dst.Value2
    
    For r = 1 To src.Rows.Count
        If Not ResolveYearMonthForRow(src.Worksheet, src.Row + r - 1, src.Column, yy, mm, lastKnownYear) Then
            GoTo NextRow
        End If
        
        For c = 1 To src.Columns.Count
            Dim d As Long
            d = c
            If d > Day(DateSerial(yy, mm + 1, 0)) Then GoTo NextCol
            
            Dim dt As Date
            dt = DateSerial(yy, mm, d)
            If dt >= retirementDate Then
                dstArr(r, c) = vbNullString
            End If
            
NextCol:
        Next c
NextRow:
    Next r
    
    dst.Value2 = dstArr
    LogDebug "Po datumu upokojitve je plan v VpisiDopuste počiščen (>=" & Format$(retirementDate, "dd.mm.yyyy") & ", optimizirano z matriko)."
End Sub

Private Sub HighlightImportantDates(ByVal src As Range, ByVal dst As Range, ByVal retirementDate As Date)
    ClearPreviousImportantDateHighlights dst
    
    Dim cutoffDate As Date
    Dim lastWorkDate As Date
    lastWorkDate = LastWorkingDay(retirementDate)
    cutoffDate = DateAdd("d", -45, lastWorkDate)
    
    Dim actualDiff As Long
    actualDiff = DateDiff("d", cutoffDate, lastWorkDate)
    If actualDiff <> 45 Then
        Err.Raise vbObjectError + 703, , "Neujemanje MEJA G: razlika ni 45 dni (trenutno: " & actualDiff & ")."
    End If
    
    Dim r As Long, c As Long
    Dim yy As Long, mm As Long
    Dim lastKnownYear As Long
    Dim foundRetirement As Boolean
    Dim foundCutoff As Boolean
    
    For r = 1 To src.Rows.Count
        If Not ResolveYearMonthForRow(src.Worksheet, src.Row + r - 1, src.Column, yy, mm, lastKnownYear) Then
            GoTo NextRow
        End If
        
        For c = 1 To src.Columns.Count
            Dim d As Long
            d = c
            If d > Day(DateSerial(yy, mm + 1, 0)) Then GoTo NextCol
            
            Dim dt As Date
            dt = DateSerial(yy, mm, d)
            
            If dt = retirementDate Then
                MarkCellImportant dst.Cells(r, c), "UPOKOJITEV"
                foundRetirement = True
                LogDebug "Označen datum upokojitve v VpisiDopuste: " & Format$(dt, "dd.mm.yyyy")
            ElseIf dt = cutoffDate Then
                MarkCellImportant dst.Cells(r, c), "MEJA G (" & actualDiff & " dni prej)"
                foundCutoff = True
                LogDebug "Označen datum 45 dni pred zadnjim delovnim dnem v VpisiDopuste: " & Format$(dt, "dd.mm.yyyy")
            End If
            
NextCol:
        Next c
NextRow:
    Next r
    
    If Not foundRetirement Then
        LogDebug "Datum upokojitve ni viden v območju VpisiDopuste: " & Format$(retirementDate, "dd.mm.yyyy")
    End If
    If Not foundCutoff Then
        LogDebug "Datum 45 dni pred zadnjim delovnim dnem ni viden v območju VpisiDopuste: " & Format$(cutoffDate, "dd.mm.yyyy")
    End If
End Sub

Private Sub ClearPreviousImportantDateHighlights(ByVal dst As Range)
    Dim cell As Range
    
    For Each cell In dst.Cells
        If Not cell.Comment Is Nothing Then
            cell.Comment.Delete
            cell.Interior.Pattern = xlNone
            cell.Font.Bold = True
        End If
    Next cell
    
    LogDebug "Počiščene prejšnje označitve ključnih datumov in komentarji v VpisiDopuste."
End Sub

Private Sub MarkCellImportant(ByVal target As Range, ByVal noteText As String)
    With target
        If Not .Comment Is Nothing Then .Comment.Delete
        .AddComment noteText
        .Comment.Visible = False
    End With
End Sub

Private Function ReadDateFromCell(ByVal target As Range, ByVal label As String) As Date
    If Not IsDate(target.Value) Then
        Err.Raise vbObjectError + 701, , "Neveljaven datum v " & label & "."
    End If
    ReadDateFromCell = DateValue(CDate(target.Value))
End Function
'Uredi planItems po datumu veljavnosti, od najzgodnejšega proti najpoznejšemu.
Private Sub SortLeaveItemsByValidity(ByRef items As Collection)
    Dim arr() As Variant
    ReDim arr(1 To items.Count)

    Dim i As Long, j As Long
    For i = 1 To items.Count
        arr(i) = items(i)
    Next i

    For i = 1 To UBound(arr) - 1
        For j = i + 1 To UBound(arr)
            If CDate(arr(j)(2)) < CDate(arr(i)(2)) Then
                Dim tmp As Variant
                tmp = arr(i)
                arr(i) = arr(j)
                arr(j) = tmp
            End If
        Next j
    Next i

    Do While items.Count > 0
        items.Remove 1
    Loop

    For i = 1 To UBound(arr)
        items.Add arr(i)
    Next i
End Sub

Private Sub SortLeaveItemsByPriority(ByRef items As Collection, ByVal retirementDate As Date)
    Dim arr() As Variant
    ReDim arr(1 To items.Count)
    
    Dim gCutoffDate As Date
    gCutoffDate = DateAdd("d", -45, LastWorkingDay(retirementDate))

    Dim i As Long, j As Long
    For i = 1 To items.Count
        arr(i) = items(i)
    Next i

    For i = 1 To UBound(arr) - 1
        For j = i + 1 To UBound(arr)
            Dim pI As Long, pJ As Long
            Dim endI As Date, endJ As Date
            
            endI = EffectiveEndForSorting(CStr(arr(i)(0)), CDate(arr(i)(2)), retirementDate, gCutoffDate)
            endJ = EffectiveEndForSorting(CStr(arr(j)(0)), CDate(arr(j)(2)), retirementDate, gCutoffDate)
            pI = LeavePriority(CStr(arr(i)(0)))
            pJ = LeavePriority(CStr(arr(j)(0)))
            
            If endJ < endI Or (endJ = endI And (pJ < pI Or (pJ = pI And CDate(arr(j)(2)) < CDate(arr(i)(2))))) Then
                Dim tmp As Variant
                tmp = arr(i)
                arr(i) = arr(j)
                arr(j) = tmp
            End If
        Next j
    Next i

    Do While items.Count > 0
        items.Remove 1
    Loop

    For i = 1 To UBound(arr)
        items.Add arr(i)
    Next i
End Sub

Private Function EffectiveEndForSorting(ByVal leaveCode As String, ByVal validUntil As Date, ByVal retirementDate As Date, ByVal gCutoffDate As Date) As Date
    Dim effectiveEnd As Date
    effectiveEnd = BaseEffectiveEndDate(leaveCode, validUntil, retirementDate)
    effectiveEnd = ApplyLeaveTypeHardStops(leaveCode, effectiveEnd, retirementDate, gCutoffDate)
    
    EffectiveEndForSorting = effectiveEnd
End Function

Private Function BaseEffectiveEndDate(ByVal leaveCode As String, ByVal validUntil As Date, ByVal retirementDate As Date) As Date
    Dim candidate As Date
    candidate = LastWorkingDay(retirementDate)
    If validUntil < candidate Then candidate = validUntil
    
    Dim hardLDate As Date
    hardLDate = HardStopDateForLeaveCode(leaveCode, retirementDate)
    If hardLDate > 0 And hardLDate < candidate Then candidate = hardLDate
    
    BaseEffectiveEndDate = candidate
End Function

Private Function ApplyLeaveTypeHardStops(ByVal leaveCode As String, ByVal effectiveEnd As Date, ByVal retirementDate As Date, ByVal gCutoffDate As Date) As Date
    Dim resultDate As Date
    resultDate = effectiveEnd
    
    If (UCase$(Trim$(leaveCode)) = "G" Or UCase$(Trim$(leaveCode)) = "GL" Or UCase$(Trim$(leaveCode)) = "GP") Then
        If gCutoffDate < resultDate Then
            resultDate = gCutoffDate
        End If
    End If
    
    ApplyLeaveTypeHardStops = resultDate
End Function

Private Function HardStopDateForLeaveCode(ByVal leaveCode As String, ByVal retirementDate As Date) As Date
    Select Case UCase$(Trim$(leaveCode))
        Case "L"
            HardStopDateForLeaveCode = DateSerial(Year(retirementDate), 6, 30)
        Case Else
            HardStopDateForLeaveCode = 0
    End Select
End Function

Private Sub WarnIfLeavesCannotBeCombined(ByVal src As Range, ByVal dst As Range, ByVal retirementDate As Date, ByVal totalAssignedLeaves As Long)
    If totalAssignedLeaves <= 0 Then Exit Sub
    
    Dim scheduleDates() As Double
    Dim scheduleR() As Long
    Dim scheduleC() As Long
    Dim scheduleCount As Long
    
    CollectRetirementEligibleShifts src, LastWorkingDay(retirementDate), scheduleDates, scheduleR, scheduleC, scheduleCount
    If scheduleCount = 0 Then Exit Sub
    
    SortSchedulesByDateDesc scheduleDates, scheduleR, scheduleC, scheduleCount
    
    Dim horizon As Long
    horizon = totalAssignedLeaves
    If horizon > scheduleCount Then horizon = scheduleCount
    
    Dim uncoveredInsideHorizon As Long
    uncoveredInsideHorizon = CountUncoveredInHorizon(src, dst, scheduleR, scheduleC, horizon)
    
    If uncoveredInsideHorizon > 0 Then
        Dim msg As String
        msg = "Dopustov ni mogoče združiti v neprekinjen blok od datuma upokojitve nazaj." & vbCrLf & _
              "Nepokritih izmen znotraj ciljanega obdobja: " & uncoveredInsideHorizon & "." & vbCrLf & _
              "Razlog je lahko v pravilih veljavnosti (npr. L do 30.6. ali G/GL/GP 45 dni pred zadnjim delovnim dnem)."
        LogDebug msg
        ShowUserMessage msg, vbExclamation
    End If
End Sub

Private Function CountUncoveredInHorizon(ByVal src As Range, ByVal dst As Range, ByRef scheduleR() As Long, ByRef scheduleC() As Long, ByVal horizon As Long) As Long
    Dim i As Long
    For i = 1 To horizon
        If dst.Cells(scheduleR(i), scheduleC(i)).Value = src.Cells(scheduleR(i), scheduleC(i)).Value Then
            CountUncoveredInHorizon = CountUncoveredInHorizon + 1
        End If
    Next i
End Function

Private Sub CollectRetirementEligibleShifts(ByVal src As Range, ByVal retirementDate As Date, ByRef outDates() As Double, ByRef outR() As Long, ByRef outC() As Long, ByRef outCount As Long)
    Dim r As Long, c As Long
    Dim yy As Long, mm As Long
    Dim lastKnownYear As Long
    
    For r = 1 To src.Rows.Count
        If Not ResolveYearMonthForRow(src.Worksheet, src.Row + r - 1, src.Column, yy, mm, lastKnownYear) Then
            GoTo NextRow
        End If
        
        For c = 1 To src.Columns.Count
            If c > Day(DateSerial(yy, mm + 1, 0)) Then GoTo NextCol
            
            Dim dt As Date
            dt = DateSerial(yy, mm, c)
            If dt > retirementDate Then GoTo NextCol
            
            Dim shiftCode As String
            shiftCode = Trim$(CStr(src.Cells(r, c).Value))
            If Len(shiftCode) = 0 Then GoTo NextCol
            
            outCount = outCount + 1
            ReDim Preserve outDates(1 To outCount)
            ReDim Preserve outR(1 To outCount)
            ReDim Preserve outC(1 To outCount)
            outDates(outCount) = CDbl(dt)
            outR(outCount) = r
            outC(outCount) = c
            
NextCol:
        Next c
NextRow:
    Next r
End Sub

Private Sub SortSchedulesByDateDesc(ByRef dt() As Double, ByRef rr() As Long, ByRef cc() As Long, ByVal cnt As Long)
    Dim i As Long, j As Long
    Dim tmpD As Double, tmpL As Long
    
    For i = 1 To cnt - 1
        For j = i + 1 To cnt
            If dt(j) > dt(i) Then
                tmpD = dt(i): dt(i) = dt(j): dt(j) = tmpD
                tmpL = rr(i): rr(i) = rr(j): rr(j) = tmpL
                tmpL = cc(i): cc(i) = cc(j): cc(j) = tmpL
            End If
        Next j
    Next i
End Sub

Public Sub PredlagajNajboljsiDatumUpokojitve()
    On Error GoTo FailHandler
    
    Dim wS As Worksheet
    Set wS = ActiveSheet
    
    Dim retirementMonth As Variant, retirementYear As Variant
    retirementMonth = Application.InputBox("Vnesi mesec upokojitve (1-12):", "Predlog datuma upokojitve", Month(Date), , , , , 1)
    If retirementMonth = False Then Exit Sub
    retirementYear = Application.InputBox("Vnesi leto upokojitve (npr. 2026):", "Predlog datuma upokojitve", Year(Date), , , , , 1)
    If retirementYear = False Then Exit Sub
    
    If CLng(retirementMonth) < 1 Or CLng(retirementMonth) > 12 Then
        Err.Raise vbObjectError + 801, , "Mesec mora biti med 1 in 12."
    End If
    If CLng(retirementYear) < 1900 Then
        Err.Raise vbObjectError + 802, , "Leto upokojitve ni veljavno."
    End If
    
    Dim src As Range, dst As Range
    Set src = wS.Range("RazporedDelavca")
    Set dst = wS.Range("VpisiDopuste")
    
    Dim blocked As Object
    Set blocked = ParseBlockedShifts(CStr(wS.Range("D12").Value))
    
    Dim baseItems As Collection
    Set baseItems = ReadLeaveItemsFixed(wS)
    If baseItems.Count = 0 Then
        ShowUserMessage "Ni dopustov za simulacijo (E5:E9).", vbExclamation
        Exit Sub
    End If
    
    Dim e26Annual As Double
    If Not IsNumeric(wS.Range("E26").Value) Then
        Err.Raise vbObjectError + 803, , "Celica E26 mora vsebovati število letnega dopusta."
    End If
    e26Annual = CDbl(wS.Range("E26").Value)
    
    Dim shiftDates() As Double
    Dim shiftCodes() As String
    Dim shiftCount As Long
    CollectEligibleShiftDates src, blocked, shiftDates, shiftCodes, shiftCount
    If shiftCount = 0 Then
        ShowUserMessage "V razporedu ni izmen za simulacijo.", vbExclamation
        Exit Sub
    End If
    
    Dim bestDate As Date
    Dim bestHoles As Long
    bestHoles = 999999
    Dim bestAssigned As Long
    bestAssigned = -1
    Dim bestRequested As Long
    
    Dim d As Long
    Dim maxDay As Long
    maxDay = Day(DateSerial(CLng(retirementYear), CLng(retirementMonth) + 1, 0))
    
    mSuppressUserMessages = True
    
    For d = 1 To maxDay
        Dim candidate As Date
        candidate = DateSerial(CLng(retirementYear), CLng(retirementMonth), d)

        Dim simItems As Collection
        Set simItems = BuildSimulationItems(baseItems, candidate, e26Annual)
        SortLeaveItemsByPriority simItems, candidate
        
        Dim totalRequested As Long
        totalRequested = SumRequestedDays(simItems)

        Dim totalAssigned As Long, holes As Long
        SimulateCoverageFast shiftDates, shiftCount, simItems, candidate, totalAssigned, holes
        
        If holes < bestHoles Or (holes = bestHoles And totalAssigned > bestAssigned) Then
            bestHoles = holes
            bestAssigned = totalAssigned
            bestRequested = totalRequested
            bestDate = candidate
        End If
    Next d
    
    mSuppressUserMessages = False
    
    If bestDate = 0 Then
        ShowUserMessage "Ni mogoče izračunati predloga datuma upokojitve.", vbExclamation
    Else
        ShowUserMessage "Predlagan datum upokojitve: " & Format$(bestDate, "dd.mm.yyyy") & vbCrLf & _
                        "Nepokrite izmene v ciljnem obdobju: " & bestHoles & vbCrLf & _
                        "Skupno planiranih dni dopusta: " & bestAssigned & vbCrLf & _
                        "Skupno zahtevanih dni dopusta: " & bestRequested, vbInformation
    End If
    
    Exit Sub
    
FailHandler:
    mSuppressUserMessages = False
    ShowUserMessage "Napaka pri izračunu predloga datuma upokojitve: " & Err.Description, vbCritical
End Sub

Private Function BuildSimulationItems(ByVal srcItems As Collection, ByVal candidateDate As Date, ByVal e26Annual As Double) As Collection
    Dim result As New Collection
    Dim yearStart As Date
    yearStart = DateSerial(Year(candidateDate), 1, 1)
    Dim elapsedDays As Long
    elapsedDays = DateDiff("d", yearStart, LastWorkingDay(candidateDate)) + 1
    If elapsedDays < 0 Then elapsedDays = 0
    
    Dim i As Long
    For i = 1 To srcItems.Count
        Dim code As String
        code = UCase$(Trim$(CStr(srcItems(i)(0))))
        
        Dim qty As Long
        qty = CLng(srcItems(i)(1))
        
        If code = "D" Then
            qty = CLng(Fix((elapsedDays / 365#) * e26Annual))
            If qty < 0 Then qty = 0
        End If
        
        result.Add Array(code, qty, CDate(srcItems(i)(2)))
    Next i
    Set BuildSimulationItems = result
End Function

Private Function SumRequestedDays(ByVal items As Collection) As Long
    Dim i As Long
    For i = 1 To items.Count
        SumRequestedDays = SumRequestedDays + CLng(items(i)(1))
    Next i
End Function

Private Sub CollectEligibleShiftDates(ByVal src As Range, ByVal blocked As Object, ByRef outDates() As Double, ByRef outCodes() As String, ByRef outCount As Long)
    Dim r As Long, c As Long
    Dim yy As Long, mm As Long
    Dim lastKnownYear As Long
    
    For r = 1 To src.Rows.Count
        If Not ResolveYearMonthForRow(src.Worksheet, src.Row + r - 1, src.Column, yy, mm, lastKnownYear) Then
            GoTo NextRow
        End If
        
        For c = 1 To src.Columns.Count
            If c > Day(DateSerial(yy, mm + 1, 0)) Then GoTo NextCol
            
            Dim dt As Date
            dt = DateSerial(yy, mm, c)
            
            Dim shiftCode As String
            shiftCode = Trim$(CStr(src.Cells(r, c).Value))
            If Len(shiftCode) = 0 Then GoTo NextCol
            If blocked.Exists(UCase$(shiftCode)) Then GoTo NextCol
            
            outCount = outCount + 1
            ReDim Preserve outDates(1 To outCount)
            ReDim Preserve outCodes(1 To outCount)
            outDates(outCount) = CDbl(dt)
            outCodes(outCount) = shiftCode
            
NextCol:
        Next c
NextRow:
    Next r
End Sub

Private Sub SimulateCoverageFast(ByRef shiftDates() As Double, ByVal shiftCount As Long, ByVal items As Collection, ByVal retirementDate As Date, ByRef outAssigned As Long, ByRef outHoles As Long)
    If shiftCount <= 0 Then Exit Sub
    
    Dim sortedDates() As Double
    ReDim sortedDates(1 To shiftCount)
    Dim i As Long
    For i = 1 To shiftCount
        sortedDates(i) = shiftDates(i)
    Next i
    SortDateArrayDesc sortedDates, shiftCount
    
    Dim assigned() As Boolean
    ReDim assigned(1 To shiftCount)
    
    Dim cutoff As Date
    cutoff = DateAdd("d", -45, lastWorkDate)
    
    Dim itIdx As Long
    For itIdx = 1 To items.Count
        Dim it As Variant
        it = items(itIdx)
        
        Dim code As String
        code = UCase$(Trim$(CStr(it(0))))
        Dim qty As Long
        qty = CLng(it(1))
        If qty <= 0 Then GoTo NextItem
        
        Dim effectiveEnd As Date
        effectiveEnd = EffectiveEndForSorting(code, CDate(it(2)), retirementDate, cutoff)
        
        For i = 1 To shiftCount
            If qty <= 0 Then Exit For
            If assigned(i) Then GoTo NextShift
            If CDate(sortedDates(i)) > lastWorkDate Then GoTo NextShift
            If CDate(sortedDates(i)) > effectiveEnd Then GoTo NextShift
            
            assigned(i) = True
            outAssigned = outAssigned + 1
            qty = qty - 1
NextShift:
        Next i
NextItem:
    Next itIdx
    
    Dim foundAssigned As Boolean
    Dim earliestAssigned As Date
    earliestAssigned = lastWorkDate
    
    For i = 1 To shiftCount
        If assigned(i) And CDate(sortedDates(i)) <= lastWorkDate Then
            If Not foundAssigned Then
                earliestAssigned = CDate(sortedDates(i))
                foundAssigned = True
            ElseIf CDate(sortedDates(i)) < earliestAssigned Then
                earliestAssigned = CDate(sortedDates(i))
            End If
        End If
    Next i
    
    If Not foundAssigned Then Exit Sub
    
    For i = 1 To shiftCount
        Dim dt As Date
        dt = CDate(sortedDates(i))
        If dt > lastWorkDate Then GoTo NextHole
        If dt < earliestAssigned Then GoTo NextHole
        If Not assigned(i) Then outHoles = outHoles + 1
NextHole:
    Next i
End Sub

Private Function LastWorkingDay(ByVal retirementDate As Date) As Date
    LastWorkingDay = DateAdd("d", -1, retirementDate)
End Function

Private Sub SortDateArrayDesc(ByRef dt() As Double, ByVal cnt As Long)
    Dim i As Long, j As Long
    Dim tmpD As Double
    For i = 1 To cnt - 1
        For j = i + 1 To cnt
            If dt(j) > dt(i) Then
                tmpD = dt(i): dt(i) = dt(j): dt(j) = tmpD
            End If
        Next j
    Next i
End Sub

Private Sub ShowUserMessage(ByVal text As String, ByVal style As VbMsgBoxStyle)
    If mSuppressUserMessages Then Exit Sub
    MsgBox text, style
End Sub

Private Function LeavePriority(ByVal leaveCode As String) As Long
    Dim key As String
    key = UCase$(Trim$(leaveCode))
    
    Select Case key
        Case "D": LeavePriority = 1
        Case "L": LeavePriority = 2
        Case "G": LeavePriority = 3
        Case "GL": LeavePriority = 4
        Case "GP": LeavePriority = 5
        Case Else: LeavePriority = 99
    End Select
End Function

Private Sub SwapCandidate(ByRef candR() As Long, ByRef candC() As Long, ByRef candDt() As Double, ByVal i As Long, ByVal j As Long)
    Dim tmpL As Long
    Dim tmpD As Double
    
    tmpL = candR(i): candR(i) = candR(j): candR(j) = tmpL
    tmpL = candC(i): candC(i) = candC(j): candC(j) = tmpL
    tmpD = candDt(i): candDt(i) = candDt(j): candDt(j) = tmpD
End Sub

Private Function ResolveYearMonthForRow(ByVal wS As Worksheet, ByVal absRow As Long, ByVal dayStartCol As Long, ByRef y As Long, ByRef m As Long, ByRef lastKnownYear As Long) As Boolean
    Dim monthText As String
    monthText = Trim$(CStr(wS.Cells(absRow, dayStartCol - 1).Value))

    Dim meseci As Variant
    meseci = Array("jan", "feb", "mar", "apr", "maj", "jun", "jul", "avg", "sep", "okt", "nov", "dec")

    Dim key As String
    key = LCase$(Replace(monthText, ".", ""))

    Dim monthIdx As Variant
    monthIdx = Application.Match(key, meseci, 0)
    If IsError(monthIdx) Then Exit Function
    m = CLng(monthIdx)

    Dim yearRaw As Variant
    yearRaw = wS.Cells(absRow, dayStartCol - 2).Value

    If IsNumeric(yearRaw) And CLng(yearRaw) > 1900 Then
        y = CLng(yearRaw)
        lastKnownYear = y
    ElseIf lastKnownYear > 1900 Then
        y = lastKnownYear
    Else
        Exit Function
    End If

    ResolveYearMonthForRow = True
End Function

Private Function MonthFromSlAbbrev(ByVal mon As String) As Long
    Dim key As String
    key = LCase$(Replace(mon, ".", ""))

    Select Case key
        Case "jan": MonthFromSlAbbrev = 1
        Case "feb": MonthFromSlAbbrev = 2
        Case "mar": MonthFromSlAbbrev = 3
        Case "apr": MonthFromSlAbbrev = 4
        Case "maj": MonthFromSlAbbrev = 5
        Case "jun": MonthFromSlAbbrev = 6
        Case "jul": MonthFromSlAbbrev = 7
        Case "avg": MonthFromSlAbbrev = 8
        Case "sep": MonthFromSlAbbrev = 9
        Case "okt": MonthFromSlAbbrev = 10
        Case "nov": MonthFromSlAbbrev = 11
        Case "dec": MonthFromSlAbbrev = 12
        Case Else: MonthFromSlAbbrev = 0
    End Select
End Function

Private Sub WriteAssignedQty(ByVal wS As Worksheet, ByVal leaveCode As String, ByVal assignedQty As Long)
    Select Case UCase$(Trim$(leaveCode))
        Case "L":  wS.Range("E16").Value = assignedQty
        Case "D":  wS.Range("E17").Value = assignedQty
        Case "GP": wS.Range("E18").Value = assignedQty
        Case "GL": wS.Range("E19").Value = assignedQty
        Case "G":  wS.Range("E20").Value = assignedQty
    End Select
End Sub


