
Option Explicit

Private Const DEBUG_MODE As Boolean = True

'========================================================================
'============= PRIPRAVI PREDLOG IZRABE DOPUSTA PRED PENZIJO =============
'========================================================================

Public Sub ZazeniPredlogIzrabe()
    On Error GoTo Konec
    
    frmLoading.Show vbModeless
    DoEvents
    SetLoaderProgress 0, "Začenjam..."
    
    Call PripraviPredlogIzrabe
    
Konec:
    Unload frmLoading
End Sub

Public Sub PripraviPredlogIzrabe()
    On Error GoTo FailHandler

    LogDebug "=== ZAGON PripraviPredlogIzrabe ==="
    SetLoaderProgress 5, "Začenjam..."

    Dim wS As Worksheet
    Set wS = ActiveSheet
    
    'Preberemo datum upokojitve v E3; ReadDateFromCell preveri ali je res datum
    Dim retirementDate As Date
    retirementDate = ReadDateFromCell(wS.Range("E3"), "E3 (datum upokojitve)")
    LogDebug "Datum upokojitve: " & Format$(retirementDate, "dd.mm.yyyy")

    'Preberemo blokirane izmene, ki jih ne prepišemo z dopustom
    Dim blocked As Object
    Set blocked = ParseBlockedShifts(CStr(wS.Range("D12").Value))

    'ustvarimo prazen seznam
    Dim planItems As Collection
    'pokličemo funkcijo, ki sestavi seznam
    Set planItems = ReadLeaveItemsFixed(wS)
    
    If planItems.Count = 0 Then
        SetLoaderProgress 100, "Ni dopustov za planiranje."
        MsgBox "Ni dopustov za planiranje (E5:E9).", vbExclamation
        Exit Sub
    End If
    LogDebug "Število tipov dopusta za planiranje: " & planItems.Count
    
    'Pozenemo sortiranje po prioriteti: D, L, G, GL, GP
    SortLeaveItemsByPriority planItems, retirementDate

    Dim src As Range
    Dim dst As Range
    
    Set src = wS.Range("RazporedDelavca")
    Set dst = wS.Range("VpisiDopuste")
    SetLoaderProgress 20, "Pripravljam območja..."

    LogDebug "Vir urnika: " & src.Address(False, False) & " (ime: " & GetRangeName(src) & ")"
    LogDebug "Cilj vpisa: " & dst.Address(False, False) & " (ime: VpisiDopuste)"

    'Če območji nista enaki
    If src.Rows.Count <> dst.Rows.Count Or src.Columns.Count <> dst.Columns.Count Then
        Err.Raise vbObjectError + 501, , "Območji RazporedDelavca in VpisiDopuste morata biti enake velikosti."
    End If
    
    'pobriše VpisiDopuste matriko
    dst.Value = src.Value
    wS.Range("E16:E20").ClearContents
    LogDebug "VpisiDopuste in Razporejen dopust je počiščen."
    
    ClearPostRetirementPlan src, dst, retirementDate
    SetLoaderProgress 30, "Čistim in označujem datume..."
    HighlightImportantDates src, dst, retirementDate

    Dim i As Long
    'Zanka po vseh dopustih, ki jih je potrebno razporediti
    For i = 1 To planItems.Count
        SetLoaderProgress 30 + CLng((i - 1) * 60 / planItems.Count), "Planiram tip " & CStr(planItems(i)(0)) & "..."
        Dim item As Variant
        item = planItems(i) ' item(0)=Code, item(1)=Qty, item(2)=ValidUntil
        LogDebug "Začenjam tip: " & CStr(item(0)) & ", qty=" & CLng(item(1)) & ", veljavnost=" & Format$(CDate(item(2)), "dd.mm.yyyy")
        'GLAVNI DEL MAKROJA, PLANIRANJE DOPUSTA; VHODNI PODATKI: RazporedDelavca, matrika VpisiDopuste, blokirane izmene, Upokojitveni datum,
        ' item(0) - oznaka dopusta, item(1) - stevilo dni, item(2) - veljaven do
        'FunkcijaPlanOneLeaveItem vrne splanirane dopuste, kar zapišemo v assignedQty
        Dim assignedQty As Long
        assignedQty = PlanOneLeaveItem(src, dst, blocked, retirementDate, CStr(item(0)), CLng(item(1)), CDate(item(2)))
        'Zapisemo planirane dopuste
        WriteAssignedQty wS, CStr(item(0)), assignedQty
    Next i

    SetLoaderProgress 100, "Zaključujem..."
    LogDebug "=== KONEC PripraviPredlogIzrabe ==="
    MsgBox "Predlog izrabe je pripravljen v območju VpisiDopuste.", vbInformation
    Exit Sub

FailHandler:
    SetLoaderProgress 100, "Napaka."
    LogDebug "NAPAKA: " & Err.Description
    MsgBox "Napaka: " & Err.Description, vbCritical
End Sub

Private Function GetRangeName(ByVal rng As Range) As String
    Dim n As Name
    For Each n In rng.Worksheet.Parent.Names
        On Error Resume Next
        If n.RefersToRange.Address = rng.Address Then
            GetRangeName = n.Name
            Exit Function
        End If
        On Error GoTo 0
    Next n
    GetRangeName = "(brez imena)"
End Function


'Funkcija ustvari seznam in pokliče funkcijo, ki preveri dopuste in jih doda v seznam
Private Function ReadLeaveItemsFixed(ByVal wS As Worksheet) As Collection
    'prazen seznam
    Dim result As New Collection
    
    '5x pokliče AddLeaveIfAny:
    AddLeaveIfAny result, wS.Range("D5").Value, wS.Range("E5").Value, wS.Range("F5").Value
    AddLeaveIfAny result, wS.Range("D6").Value, wS.Range("E6").Value, wS.Range("F6").Value
    AddLeaveIfAny result, wS.Range("D7").Value, wS.Range("E7").Value, wS.Range("F7").Value
    AddLeaveIfAny result, wS.Range("D8").Value, wS.Range("E8").Value, wS.Range("F8").Value
    AddLeaveIfAny result, wS.Range("D9").Value, wS.Range("E9").Value, wS.Range("F9").Value

    Set ReadLeaveItemsFixed = result
End Function
'Funkcija pridobi: prazen seznam result, leaveCode = "L, D,...", qtyVal = 5,... validVal = 31.12.2026
Private Sub AddLeaveIfAny(ByRef col As Collection, ByVal leaveCode As String, ByVal qtyVal As Variant, ByVal validVal As Variant)
    If Not IsNumeric(qtyVal) Then Exit Sub
    If CLng(qtyVal) <= 0 Then Exit Sub
    If Not IsDate(validVal) Then
        Err.Raise vbObjectError + 601, , "Veljavnost ni datum za tip " & leaveCode & "."
    End If
    'dodajanje v seznam
    col.Add Array(leaveCode, CLng(qtyVal), DateValue(CDate(validVal)))
End Sub

Private Function ParseBlockedShifts(ByVal raw As String) As Object
    Dim dict As Object
    Set dict = CreateObject("Scripting.Dictionary")
    dict.CompareMode = 1 ' TextCompare

    Dim parts() As String
    'gre čez vse dele, odstrani presledke in jih zapiše v slovar
    Dim i As Long
    ' ločilo je vejica
    parts = Split(raw, ",")
    For i = LBound(parts) To UBound(parts)
        Dim token As String
        token = Trim$(parts(i))
        If Len(token) > 0 Then
            dict(UCase$(token)) = True
            LogDebug "Blokirana izmena: " & UCase$(token)
        End If
    Next i

    Set ParseBlockedShifts = dict
End Function
'====================================================================================================================
' ========================== GLAVNI MOTOR MAKROJA: PISANJE DOPUSTOV =================================================
'====================================================================================================================
Private Function PlanOneLeaveItem(ByVal src As Range, ByVal dst As Range, ByVal blocked As Object, ByVal retirementDate As Date, ByVal leaveCode As String, ByVal leaveQty As Long, ByVal validUntil As Date) As Long
    'Koliko dopusta še ni razporejeno
    Dim remaining As Long
    remaining = leaveQty
    
    Dim effectiveEndDate As Date
    If validUntil < retirementDate Then
        effectiveEndDate = validUntil
    Else
        effectiveEndDate = retirementDate
    End If
    
    Dim scheduleMinDate As Date, scheduleMaxDate As Date
    GetScheduleDateBounds src, scheduleMinDate, scheduleMaxDate
    effectiveEndDate = AlignEndDateToVisibleSchedule(effectiveEndDate, scheduleMinDate, scheduleMaxDate, retirementDate)
    
    Dim hasValidityWindow As Boolean                    ' Obstaja časovno okno, kjer se planiranje dopustov izzide
    Dim gCutoffDate As Date                             'omejitev za planiranje G-jev
    gCutoffDate = DateAdd("d", -45, retirementDate)
    
    If (UCase$(leaveCode) = "G" Or UCase$(leaveCode) = "GL" Or UCase$(leaveCode) = "GP") Then
        If DateAdd("d", -1, gCutoffDate) < effectiveEndDate Then
            effectiveEndDate = DateAdd("d", -1, gCutoffDate)
        End If
    End If

    Dim r As Long, c As Long
    Dim lastKnownYear As Long                           'v resnici števec stolpcev

    Dim candR() As Long, candC() As Long, candDt() As Double
    Dim candCount As Long
    
    For r = 1 To src.Rows.Count

        Dim rowLabel As String                          ' meseci ?
        rowLabel = CStr(src.Worksheet.Cells(src.Row + r - 1, src.Column - 1).Value)

        Dim yy As Long, mm As Long
        'pregleda leto in mesec in ga spravi v pravi format
        If Not ResolveYearMonthForRow(src.Worksheet, src.Row + r - 1, src.Column, yy, mm, lastKnownYear) Then
            LogDebug "[" & leaveCode & "] Preskok vrstice (neveljaven mesec/leto): '" & rowLabel & "'"
            GoTo NextRow
        End If

        LogDebug "[" & leaveCode & "] Pregled vrstice: " & yy & " " & rowLabel

        For c = 1 To src.Columns.Count
            
            'Preverjanje ali ta dan sploh obstaja
            Dim d As Long
            d = c
            If d > Day(DateSerial(yy, mm + 1, 0)) Then
                LogDebug "[" & leaveCode & "] Dan " & d & " ne obstaja v mesecu " & mm & "/" & yy
                GoTo NextCol
            End If
            
            'Sestava pravega datuma
            Dim dt As Date
            dt = DateSerial(yy, mm, d)
            
            
            'Branje izmen koledarja
            Dim shiftCode As String
            shiftCode = Trim$(CStr(src.Cells(r, c).Value))

            LogDebug "[" & leaveCode & "] Dan " & Format$(dt, "dd.mm.yyyy") & _
                     " | shift='" & shiftCode & "' | remaining=" & remaining
            
            'pogleda če je dan ustrezen:
            'a) če je po zadnjem mogočem datumu za ta tip dopusta
            If dt > effectiveEndDate Then
                LogDebug "  -> preskok (po zadnjem možnem datumu: " & Format$(effectiveEndDate, "dd.mm.yyyy") & ")"
                GoTo NextCol
            End If
            'Če najdemo vsaj 1 datum, ki je datumsko še mogoč
            hasValidityWindow = True
            
            'Če je prazna celica, jo preskoči
            If Len(shiftCode) = 0 Then
                LogDebug "  -> preskok (prazna celica)"
                GoTo NextCol
            End If
            ' Če je blokirana celica
            If blocked.Exists(UCase$(shiftCode)) Then
                LogDebug "  -> preskok (blokirana izmena)"
                GoTo NextCol
            End If
            'Preskočimo, če je že vpisano nekaj
            If Trim$(CStr(dst.Cells(r, c).Value)) <> Trim$(CStr(src.Cells(r, c).Value)) Then
                LogDebug "  -> preskok (že prepisano v VpisiDopuste)"
                GoTo NextCol
            End If

            candCount = candCount + 1
            ReDim Preserve candR(1 To candCount)
            ReDim Preserve candC(1 To candCount)
            ReDim Preserve candDt(1 To candCount)
            candR(candCount) = r
            candC(candCount) = c
            candDt(candCount) = CDbl(dt)

NextCol:
        Next c
NextRow:
    Next r
    
    Dim idx As Long, j As Long
    For idx = 1 To candCount - 1
        For j = idx + 1 To candCount
            If candDt(j) > candDt(idx) Then
                SwapCandidate candR, candC, candDt, idx, j
            End If
        Next j
    Next idx
    
    For idx = 1 To candCount
        If remaining <= 0 Then Exit For
        dst.Cells(candR(idx), candC(idx)).Value = leaveCode
        remaining = remaining - 1
    Next idx

    If remaining > 0 Then
        If Not hasValidityWindow Then
            LogDebug "[" & leaveCode & "] ZAKLJUČEK: ni termina do " & Format$(effectiveEndDate, "dd.mm.yyyy")
            MsgBox "Za tip '" & leaveCode & "' planiranje ni možno: v tabeli ni termina do " & Format$(effectiveEndDate, "dd.mm.yyyy") & ".", vbInformation
        Else
            LogDebug "[" & leaveCode & "] ZAKLJUČEK: premalo dni, manjka " & remaining
            MsgBox "Za tip '" & leaveCode & "' ni dovolj prostih dni. Manjka: " & remaining, vbInformation
        End If
    Else
        LogDebug "[" & leaveCode & "] ZAKLJUČEK: uspešno razporejeno."
    End If
    
    'Vpišimo planirani dopust v E16-E20
    PlanOneLeaveItem = leaveQty - remaining
    
End Function

Private Sub GetScheduleDateBounds(ByVal src As Range, ByRef minDate As Date, ByRef maxDate As Date)
    Dim r As Long, c As Long
    Dim yy As Long, mm As Long
    Dim lastKnownYear As Long
    Dim found As Boolean
    
    For r = 1 To src.Rows.Count
        If Not ResolveYearMonthForRow(src.Worksheet, src.Row + r - 1, src.Column, yy, mm, lastKnownYear) Then
            GoTo NextRow
        End If
        
        For c = 1 To src.Columns.Count
            If c > Day(DateSerial(yy, mm + 1, 0)) Then GoTo NextCol
            
            Dim dt As Date
            dt = DateSerial(yy, mm, c)
            If Not found Then
                minDate = dt
                maxDate = dt
                found = True
            Else
                If dt < minDate Then minDate = dt
                If dt > maxDate Then maxDate = dt
            End If
NextCol:
        Next c
NextRow:
    Next r
End Sub

Private Function AlignEndDateToVisibleSchedule(ByVal endDate As Date, ByVal scheduleMinDate As Date, ByVal scheduleMaxDate As Date, ByVal retirementDate As Date) As Date
    Dim adjusted As Date
    adjusted = endDate
    
    If adjusted < scheduleMinDate Then
        adjusted = DateSerial(Year(scheduleMinDate), Month(adjusted), Day(adjusted))
        If adjusted < scheduleMinDate Then
            adjusted = DateAdd("yyyy", 1, adjusted)
        End If
        
        If adjusted > scheduleMaxDate Or adjusted > retirementDate Then
            adjusted = endDate
        End If
    End If
    
    AlignEndDateToVisibleSchedule = adjusted
End Function

Private Sub ClearPostRetirementPlan(ByVal src As Range, ByVal dst As Range, ByVal retirementDate As Date)
    Dim r As Long, c As Long
    Dim yy As Long, mm As Long
    Dim lastKnownYear As Long
    Dim dstArr As Variant
    
    dstArr = dst.Value2
    
    For r = 1 To src.Rows.Count
        If Not ResolveYearMonthForRow(src.Worksheet, src.Row + r - 1, src.Column, yy, mm, lastKnownYear) Then
            GoTo NextRow
        End If
        
        For c = 1 To src.Columns.Count
            Dim d As Long
            d = c
            If d > Day(DateSerial(yy, mm + 1, 0)) Then GoTo NextCol
            
            Dim dt As Date
            dt = DateSerial(yy, mm, d)
            If dt > retirementDate Then
                dstArr(r, c) = vbNullString
            End If
            
NextCol:
        Next c
NextRow:
    Next r
    
    dst.Value2 = dstArr
    LogDebug "Po datumu upokojitve je plan v VpisiDopuste počiščen (>" & Format$(retirementDate, "dd.mm.yyyy") & ", optimizirano z matriko)."
End Sub

Private Sub HighlightImportantDates(ByVal src As Range, ByVal dst As Range, ByVal retirementDate As Date)
    ClearPreviousImportantDateHighlights dst
    
    Dim cutoffDate As Date
    cutoffDate = DateAdd("d", -45, retirementDate)
    
    Dim actualDiff As Long
    actualDiff = DateDiff("d", cutoffDate, retirementDate)
    If actualDiff <> 45 Then
        Err.Raise vbObjectError + 703, , "Neujemanje MEJA G: razlika ni 45 dni (trenutno: " & actualDiff & ")."
    End If
    
    Dim r As Long, c As Long
    Dim yy As Long, mm As Long
    Dim lastKnownYear As Long
    Dim foundRetirement As Boolean
    Dim foundCutoff As Boolean
    
    For r = 1 To src.Rows.Count
        If Not ResolveYearMonthForRow(src.Worksheet, src.Row + r - 1, src.Column, yy, mm, lastKnownYear) Then
            GoTo NextRow
        End If
        
        For c = 1 To src.Columns.Count
            Dim d As Long
            d = c
            If d > Day(DateSerial(yy, mm + 1, 0)) Then GoTo NextCol
            
            Dim dt As Date
            dt = DateSerial(yy, mm, d)
            
            If dt = retirementDate Then
                MarkCellImportant dst.Cells(r, c), "UPOKOJITEV"
                foundRetirement = True
                LogDebug "Označen datum upokojitve v VpisiDopuste: " & Format$(dt, "dd.mm.yyyy")
            ElseIf dt = cutoffDate Then
                MarkCellImportant dst.Cells(r, c), "MEJA G (" & actualDiff & " dni prej)"
                foundCutoff = True
                LogDebug "Označen datum 45 dni pred upokojitvijo v VpisiDopuste: " & Format$(dt, "dd.mm.yyyy")
            End If
            
NextCol:
        Next c
NextRow:
    Next r
    
    If Not foundRetirement Then
        LogDebug "Datum upokojitve ni viden v območju VpisiDopuste: " & Format$(retirementDate, "dd.mm.yyyy")
    End If
    If Not foundCutoff Then
        LogDebug "Datum 45 dni pred upokojitvijo ni viden v območju VpisiDopuste: " & Format$(cutoffDate, "dd.mm.yyyy")
    End If
End Sub

Private Sub ClearPreviousImportantDateHighlights(ByVal dst As Range)
    Dim cell As Range
    
    For Each cell In dst.Cells
        If Not cell.Comment Is Nothing Then
            cell.Comment.Delete
            cell.Interior.Pattern = xlNone
            cell.Font.ColorIndex = xlAutomatic
            cell.Font.Bold = False
        End If
    Next cell
    
    LogDebug "Počiščene prejšnje označitve ključnih datumov in komentarji v VpisiDopuste."
End Sub

Private Sub MarkCellImportant(ByVal target As Range, ByVal noteText As String)
    With target
        If Not .Comment Is Nothing Then .Comment.Delete
        .AddComment noteText
        .Comment.Visible = False
    End With
End Sub

Private Function ReadDateFromCell(ByVal target As Range, ByVal label As String) As Date
    If Not IsDate(target.Value) Then
        Err.Raise vbObjectError + 701, , "Neveljaven datum v " & label & "."
    End If
    ReadDateFromCell = DateValue(CDate(target.Value))
End Function
'Uredi planItems po datumu veljavnosti, od najzgodnejšega proti najpoznejšemu.
Private Sub SortLeaveItemsByValidity(ByRef items As Collection)
    Dim arr() As Variant
    ReDim arr(1 To items.Count)

    Dim i As Long, j As Long
    For i = 1 To items.Count
        arr(i) = items(i)
    Next i

    For i = 1 To UBound(arr) - 1
        For j = i + 1 To UBound(arr)
            If CDate(arr(j)(2)) < CDate(arr(i)(2)) Then
                Dim tmp As Variant
                tmp = arr(i)
                arr(i) = arr(j)
                arr(j) = tmp
            End If
        Next j
    Next i

    Do While items.Count > 0
        items.Remove 1
    Loop

    For i = 1 To UBound(arr)
        items.Add arr(i)
    Next i
End Sub

Private Sub SortLeaveItemsByPriority(ByRef items As Collection, ByVal retirementDate As Date)
    Dim arr() As Variant
    ReDim arr(1 To items.Count)
    
    Dim gCutoffDate As Date
    gCutoffDate = DateAdd("d", -45, retirementDate)

    Dim i As Long, j As Long
    For i = 1 To items.Count
        arr(i) = items(i)
    Next i

    For i = 1 To UBound(arr) - 1
        For j = i + 1 To UBound(arr)
            Dim pI As Long, pJ As Long
            Dim endI As Date, endJ As Date
            
            endI = EffectiveEndForSorting(CStr(arr(i)(0)), CDate(arr(i)(2)), retirementDate, gCutoffDate)
            endJ = EffectiveEndForSorting(CStr(arr(j)(0)), CDate(arr(j)(2)), retirementDate, gCutoffDate)
            pI = LeavePriority(CStr(arr(i)(0)))
            pJ = LeavePriority(CStr(arr(j)(0)))
            
            If endJ < endI Or (endJ = endI And (pJ < pI Or (pJ = pI And CDate(arr(j)(2)) < CDate(arr(i)(2))))) Then
                Dim tmp As Variant
                tmp = arr(i)
                arr(i) = arr(j)
                arr(j) = tmp
            End If
        Next j
    Next i

    Do While items.Count > 0
        items.Remove 1
    Loop

    For i = 1 To UBound(arr)
        items.Add arr(i)
    Next i
End Sub

Private Function EffectiveEndForSorting(ByVal leaveCode As String, ByVal validUntil As Date, ByVal retirementDate As Date, ByVal gCutoffDate As Date) As Date
    Dim effectiveEnd As Date
    effectiveEnd = IIf(validUntil < retirementDate, validUntil, retirementDate)
    
    If (UCase$(Trim$(leaveCode)) = "G" Or UCase$(Trim$(leaveCode)) = "GL" Or UCase$(Trim$(leaveCode)) = "GP") Then
        If DateAdd("d", -1, gCutoffDate) < effectiveEnd Then
            effectiveEnd = DateAdd("d", -1, gCutoffDate)
        End If
    End If
    
    EffectiveEndForSorting = effectiveEnd
End Function

Private Function LeavePriority(ByVal leaveCode As String) As Long
    Dim key As String
    key = UCase$(Trim$(leaveCode))
    
    Select Case key
        Case "D": LeavePriority = 1
        Case "L": LeavePriority = 2
        Case "G": LeavePriority = 3
        Case "GL": LeavePriority = 4
        Case "GP": LeavePriority = 5
        Case Else: LeavePriority = 99
    End Select
End Function

Private Sub SwapCandidate(ByRef candR() As Long, ByRef candC() As Long, ByRef candDt() As Double, ByVal i As Long, ByVal j As Long)
    Dim tmpL As Long
    Dim tmpD As Double
    
    tmpL = candR(i): candR(i) = candR(j): candR(j) = tmpL
    tmpL = candC(i): candC(i) = candC(j): candC(j) = tmpL
    tmpD = candDt(i): candDt(i) = candDt(j): candDt(j) = tmpD
End Sub

Private Function ResolveYearMonthForRow(ByVal wS As Worksheet, ByVal absRow As Long, ByVal dayStartCol As Long, ByRef y As Long, ByRef m As Long, ByRef lastKnownYear As Long) As Boolean
    Dim monthText As String
    monthText = Trim$(CStr(wS.Cells(absRow, dayStartCol - 1).Value))

    Dim meseci As Variant
    meseci = Array("jan", "feb", "mar", "apr", "maj", "jun", "jul", "avg", "sep", "okt", "nov", "dec")

    Dim key As String
    key = LCase$(Replace(monthText, ".", ""))

    Dim monthIdx As Variant
    monthIdx = Application.Match(key, meseci, 0)
    If IsError(monthIdx) Then Exit Function
    m = CLng(monthIdx)

    Dim yearRaw As Variant
    yearRaw = wS.Cells(absRow, dayStartCol - 2).Value

    If IsNumeric(yearRaw) And CLng(yearRaw) > 1900 Then
        y = CLng(yearRaw)
        lastKnownYear = y
    ElseIf lastKnownYear > 1900 Then
        y = lastKnownYear
    Else
        Exit Function
    End If

    ResolveYearMonthForRow = True
End Function

Private Function MonthFromSlAbbrev(ByVal mon As String) As Long
    Dim key As String
    key = LCase$(Replace(mon, ".", ""))

    Select Case key
        Case "jan": MonthFromSlAbbrev = 1
        Case "feb": MonthFromSlAbbrev = 2
        Case "mar": MonthFromSlAbbrev = 3
        Case "apr": MonthFromSlAbbrev = 4
        Case "maj": MonthFromSlAbbrev = 5
        Case "jun": MonthFromSlAbbrev = 6
        Case "jul": MonthFromSlAbbrev = 7
        Case "avg": MonthFromSlAbbrev = 8
        Case "sep": MonthFromSlAbbrev = 9
        Case "okt": MonthFromSlAbbrev = 10
        Case "nov": MonthFromSlAbbrev = 11
        Case "dec": MonthFromSlAbbrev = 12
        Case Else: MonthFromSlAbbrev = 0
    End Select
End Function

Private Sub WriteAssignedQty(ByVal wS As Worksheet, ByVal leaveCode As String, ByVal assignedQty As Long)
    Select Case UCase$(Trim$(leaveCode))
        Case "L":  wS.Range("E16").Value = assignedQty
        Case "D":  wS.Range("E17").Value = assignedQty
        Case "GP": wS.Range("E18").Value = assignedQty
        Case "GL": wS.Range("E19").Value = assignedQty
        Case "G":  wS.Range("E20").Value = assignedQty
    End Select
End Sub


Private Sub LogDebug(ByVal msg As String)
    If DEBUG_MODE Then
        Debug.Print Format$(Now, "hh:nn:ss"); " | "; msg
    End If
End Sub

Private Sub SetLoaderProgress(ByVal pct As Long, ByVal msg As String)
    On Error Resume Next
    frmLoading.UpdateProgress pct, msg
    On Error GoTo 0
End Sub
